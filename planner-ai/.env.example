# planner-ai environment variables — same pattern as scraper-service
# Copy to .env and fill values

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Supported LLM_PROVIDER: google | ollama | xiaomi | nvidia | openrouter | nebius | anthropic | agentrouter | modal
LLM_PROVIDER=google
LLM_TEMPERATURE=0
# Client-level HTTP timeout. Schedule/enrich nodes wrap their own asyncio.wait_for
# on top (SCHEDULE_LLM_TIMEOUT_SECONDS / ENRICH_LLM_TIMEOUT_SECONDS).
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3

# Google AI Studio (default — Gemma 4 31B via Gemini API)
# Get API key: https://aistudio.google.com/apikey
# Free tier: ~15 req/min, ~1500 req/day cho Gemma models. Đủ cho dev + light prod.
GOOGLE_API_KEY=AIza...
LLM_MODEL_GOOGLE=gemma-4-31b-it

# Ollama daemon (alternative — chạy local hoặc proxy tới Ollama Cloud)
# Yêu cầu: cài Ollama trên host (curl -fsSL https://ollama.com/install.sh | sh),
# sau đó `ollama signin` (chỉ cần thiết cho `:cloud` model tags). Mở daemon ra
# Docker bridge bằng `Environment=OLLAMA_HOST=0.0.0.0:11434` trong systemd
# override (sudo systemctl edit ollama.service) — KHÔNG mở port 11434 ra
# Internet trên Security Group, vì Ollama không có auth built-in.
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# LLM_MODEL_OLLAMA=gemma4:31b-cloud

# OpenRouter (alternative — gọi Gemma qua proxy)
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://tripcompass.vn
# OPENROUTER_APP_NAME=Tripcompass Planner
# LLM_MODEL_OPENROUTER=google/gemma-4-31b-it:free

# NVIDIA NIM API Catalog (alternative)
# LLM_PROVIDER=nvidia
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_MODEL_NVIDIA=minimaxai/minimax-m2.7

# Xiaomi MiMo (alternative)
# LLM_PROVIDER=xiaomi
# XIAOMI_API_KEY=sk-...
# XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1
# LLM_MODEL_XIAOMI=mimo-v2-pro

# Nebius (alternative)
# LLM_PROVIDER=nebius
# NEBIUS_API_KEY=...
# LLM_MODEL_NEBIUS=meta-llama/llama-3.3-70b-instruct

# Anthropic Claude (alternative)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL_ANTHROPIC=claude-sonnet-4-20250514

# AgentRouter (alternative — access DeepSeek, GLM, etc.)
# LLM_PROVIDER=agentrouter
# AGENTROUTER_API_KEY=sk-...
# AGENTROUTER_BASE_URL=https://agentrouter.org/v1
# LLM_MODEL_AGENTROUTER=deepseek-v3.2

# ── LangSmith Tracing ─────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=Planner AI
LANGCHAIN_API_KEY=lsv2_pt_...

# ── Database (same PostgreSQL as Go backend) ───────────────────────────────────
# F2: no default credentials in the template. Set the full URL with the real
# password (matches POSTGRES_PASSWORD in the repo-root .env). The service raises
# if this is unset rather than falling back to a postgres:postgres default.
DATABASE_URL=
DB_SCHEMA=schema_travel

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
CACHE_TTL_SECONDS=3600
# F2: strong random token (>=16 chars) for the admin cache endpoints. Left
# blank so the template can't be deployed with the "change-me" default — the
# service treats blank/weak tokens as "not configured" and keeps them closed.
CACHE_ADMIN_TOKEN=

# ── External APIs ─────────────────────────────────────────────────────────────
# SerpAPI — hotel/flight/price search (same key as scraper-service)
SERPAPI_API_KEY=

# WeatherAPI.com — weather
WEATHER_API_KEY=

# Tavily — web search fallback for chat agent (place/event info beyond DB).
# Free tier: 1000 searches/month. https://tavily.com
TAVILY_API_KEY=

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_HOTEL_SEARCH=true
ENABLE_FLIGHT_SEARCH=false
ENABLE_WEATHER=true
ENABLE_REAL_PRICE_CHECK=true
ENABLE_WEB_SEARCH=true
WEB_SEARCH_MAX_RESULTS=5

# ── Tuning ────────────────────────────────────────────────────────────────────
MAX_TOOL_ROUNDS=8
TOOL_TIMEOUT_SECONDS=5
MAX_SCHEDULE_RETRIES=1
SCHEDULE_LLM_TIMEOUT_SECONDS=45
ENRICH_LLM_TIMEOUT_SECONDS=8
LLM_MAX_TOKENS=4096
