# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=openrouter
LLM_MODEL_OPENROUTER=tencent/hy3-preview:free
# Extractor LLM (can use different model for extraction)
EXTRACTOR_LLM_PROVIDER=openrouter
EXTRACTOR_LLM_MODEL=tencent/hy3-preview:free

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_HTTP_REFERER=https://tripcompass.vn
OPENROUTER_APP_NAME=Tripcompass Scraper

# Nebius (alternative)
# LLM_PROVIDER=nebius
# NEBIUS_API_KEY=...

# ── LangSmith Tracing ─────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=Scraper Service
LANGCHAIN_API_KEY=ls__...

# ── Enrichment APIs ───────────────────────────────────────────────────────────
# Apify — primary source for lat/lng + images (Google Maps)
APIFY_TOKEN=apify_api_...+

# SerpAPI — fallback for unmatched places
SERPAPI_API_KEY=...

# ── Tavily (research) ─────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8080

# ── Tuning (optional) ─────────────────────────────────────────────────────────
MAX_RESEARCH_ITERATIONS=5
SCRAPER_LLM_RETRIES=2
SCRAPER_DELAY_BETWEEN=3
SCRAPER_SEARCH_DELAY=1.0
SCRAPER_SERPAPI_DELAY=2.0
DB_MIN_ATTRACTIONS=5
DB_MIN_FOOD=6
