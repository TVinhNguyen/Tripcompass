# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  TripCompass — Production Environment Variables                            ║
# ║  Copy to .env.prod and fill in real values. NEVER commit .env.prod!        ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Docker Hub ────────────────────────────────────────────────────────────────
DOCKERHUB_USERNAME=tvinhnguyen
# IMAGE_TAG is overwritten by the CD pipeline with the git SHA (e.g. sha-abc1234)
# so the deploy is reproducible. Falls back to "latest" for manual local pulls.
IMAGE_TAG=latest

# ── Domain & TLS (Caddy reverse proxy) ───────────────────────────────────────
# DNS A record for DOMAIN must point at this server before first deploy,
# otherwise Let's Encrypt HTTP-01 challenge will fail.
DOMAIN=tripcompass.studio
ACME_EMAIL=admin@tripcompass.studio

# ── Public URL (used for CORS, frontend build, OAuth callbacks, email links) ─
PUBLIC_URL=https://tripcompass.studio
ALLOWED_ORIGINS=https://tripcompass.studio

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=tripcompass
POSTGRES_USER=tripcompass_admin
POSTGRES_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_32

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_32

# ── Backend (Go API) ─────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_USE_openssl_rand_base64_64
JWT_EXPIRE_HOURS=72
FRONTEND_URL=https://tripcompass.studio

# Email via Resend
RESEND_API_KEY=
RESEND_FROM=TripCompass <noreply@tripcompass.studio>

# Google OAuth — single source of truth for both backend and frontend.
# The frontend reads this at runtime via /runtime-config; the backend validates
# the id_token audience against it. They MUST be the same value (the Web Client
# ID from Google Cloud Console).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin emails (comma-separated)
ADMIN_EMAILS=

# ── Planner AI ────────────────────────────────────────────────────────────────
# LLM Provider — set the one you use
LLM_PROVIDER=google
LLM_TEMPERATURE=0
# Client-level HTTP timeout. Schedule/enrich nodes wrap their own asyncio.wait_for
# on top (SCHEDULE_LLM_TIMEOUT_SECONDS / ENRICH_LLM_TIMEOUT_SECONDS).
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3

# Google AI Studio — Gemma 4 31B (default)
# Get API key: https://aistudio.google.com/apikey
# Free tier: ~15 req/min, ~1500 req/day cho Gemma. Cho production multi-user
# nên upgrade paid tier hoặc setup multi-key fallback.
GOOGLE_API_KEY=AIza...
LLM_MODEL_GOOGLE=gemma-4-31b-it

# OpenRouter (alternative)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://tripcompass.studio
OPENROUTER_APP_NAME=Tripcompass Planner
LLM_MODEL_OPENROUTER=google/gemma-4-31b-it:free

# Xiaomi (alternative)
XIAOMI_API_KEY=
XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1
LLM_MODEL_XIAOMI=mimo-v2-pro

# NVIDIA (alternative)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL_NVIDIA=minimaxai/minimax-m2.7

# Anthropic
ANTHROPIC_API_KEY=
LLM_MODEL_ANTHROPIC=claude-sonnet-4-20250514

# AgentRouter
AGENTROUTER_API_KEY=
AGENTROUTER_BASE_URL=https://agentrouter.org/v1
LLM_MODEL_AGENTROUTER=deepseek-v3.2

# Modal
MODAL_API_KEY=
MODAL_BASE_URL=https://api.us-west-2.modal.direct/v1
LLM_MODEL_MODAL=zai-org/GLM-5.1-FP8

# Nebius
NEBIUS_API_KEY=
LLM_MODEL_NEBIUS=meta-llama/llama-3.3-70b-instruct

# LangSmith (optional, set to false to disable)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=TripCompass Planner

# External APIs for planner
SERPAPI_API_KEY=
WEATHER_API_KEY=

# Cache
CACHE_TTL_SECONDS=3600
CACHE_ADMIN_TOKEN=CHANGE_ME

# Feature flags
ENABLE_HOTEL_SEARCH=true
ENABLE_FLIGHT_SEARCH=false
ENABLE_WEATHER=true
ENABLE_REAL_PRICE_CHECK=true

# Planner tuning
MAX_TOOL_ROUNDS=8
TOOL_TIMEOUT_SECONDS=5
MAX_SCHEDULE_RETRIES=2
# Free-tier LLM gateways routinely need 60-90s for a full schedule prompt;
# enrichment is cosmetic and stays short.
SCHEDULE_LLM_TIMEOUT_SECONDS=90
ENRICH_LLM_TIMEOUT_SECONDS=30
# Per-request HTTP timeout and retry budget for the OpenAI-compatible client.
LLM_REQUEST_TIMEOUT=180
LLM_MAX_RETRIES=3

# ── Postgres backups (pg-backup service) ──────────────────────────────────────
# Daily dumps written to ./backups/ on the host. Adjust retention as needed.
PG_BACKUP_SCHEDULE=@daily
PG_BACKUP_KEEP_DAYS=7
PG_BACKUP_KEEP_WEEKS=4
PG_BACKUP_KEEP_MONTHS=6
