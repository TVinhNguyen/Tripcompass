# TripCompass Backend — Environment Variables
# Copy to .env and fill in real values

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
# F2: set a strong, unique password — never ship "postgres". Left blank so
# copying this template verbatim fails instead of running with a known default.
DB_PASSWORD=
DB_NAME=tripcompass
DB_SCHEMA=schema_travel

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# F2: REQUIRED — min 32 random chars. Generate with: openssl rand -base64 48
# The backend refuses to start on a blank/default/short secret (config.go).
JWT_SECRET=
JWT_EXPIRE_HOURS=72

# ── Frontend URL (for email verification links) ──────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Email via Resend (leave empty to print verification links in dev) ────────
RESEND_API_KEY=
RESEND_FROM=TripCompass <onboarding@resend.dev>

# ── Social OAuth (leave empty to disable social login) ───────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=
CACHE_ADMIN_TOKEN=

# ── Feature flags ─────────────────────────────────────────────────────────────
USE_LLM_PLANNER=true
PLANNER_AI_URL=http://localhost:8090
ALLOWED_ORIGINS=http://localhost:3000
