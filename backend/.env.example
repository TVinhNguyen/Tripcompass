# TripCompass Backend — Environment Variables
# Copy to .env and fill in real values

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=tripcompass
DB_SCHEMA=schema_travel

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRE_HOURS=72

# ── Frontend URL (for email verification links) ──────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Email via Resend (leave empty to print verification links in dev) ────────
RESEND_API_KEY=
RESEND_FROM=TripCompass <onboarding@resend.dev>

# ── Social OAuth (leave empty to disable social login) ───────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=
CACHE_ADMIN_TOKEN=

# ── Feature flags ─────────────────────────────────────────────────────────────
USE_LLM_PLANNER=true
PLANNER_AI_URL=http://localhost:8090
ALLOWED_ORIGINS=http://localhost:3000
