# Repo-root environment for docker-compose interpolation.
# Copy to .env and fill in a strong value:  cp .env.example .env
#
# F2: docker-compose.yml reads POSTGRES_PASSWORD from here (no default is baked
# into the committed compose file). It must match DB_PASSWORD in backend/.env
# and the password in planner-ai/.env so all services share the same DB.
# Generate one with:  openssl rand -base64 32
POSTGRES_PASSWORD=
